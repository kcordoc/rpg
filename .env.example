# Supabase Configuration for PokéLenny
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Public keys (safe to expose in frontend - protected by RLS policies)
# For contributors: Copy this file to .env and use the production values,
# OR create your own free Supabase project at https://supabase.com

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API Key (optional - enables location-based map generation)
# Get one from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
# Without this key, the game uses procedural fallback maps with generated street names
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ⚠️ NEVER add service role key to frontend!
# Service role keys bypass RLS - only use in backend/server functions
